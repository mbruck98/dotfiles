{
    "label": "suspend",
    "action": "loginctl suspend",
    "text": "Suspend",
    "keybind": "u"
}

{
    "label": "logout",
    "action": "hyprctl dispatch exit 0",
    "text": "Logout",
    "keybind": "e"
}

{
    "label": "shutdown",
    "action": "hyprshutdown -p 'loginctl poweroff'",
    "text": "Shutdown",
    "keybind": "s"
}

{
    "label": "reboot",
    "action": "hyprshutdown -p 'loginctl reboot'",
    "text": "Reboot",
    "keybind": "r"
}
